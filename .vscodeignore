# 排除源码和构建文件
.gitignore
.git/**
src/**
tsconfig.json
compile.sh
build.mjs
test-mcp-http.mjs
connections.example.json
**/*.map
**/tsconfig*.json
yarn.lock
package-lock.json

# node_modules - 排除开发依赖，保留所有运行时依赖
node_modules/.package-lock.json
node_modules/package-lock.json
node_modules/**/*.d.ts
node_modules/**/tsconfig.json
node_modules/@types/**
node_modules/typescript/**
node_modules/@typescript/**
node_modules/prettier/**
node_modules/eslint/**
node_modules/@eslint/**
node_modules/esbuild/**
node_modules/@esbuild/**
node_modules/vsce/**
node_modules/@electron/
